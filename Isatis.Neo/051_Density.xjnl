                                <param key="MAX_PER_SECTOR">$(par_estima_den[(par_estima_den.domain==dom_sect[j])&amp;(par_estima_den.setor==sect_den[k])].max_sector.iloc[0])</param>
                                <param key="SPLIT_SECTORS">no</param>
                            </param>
                            <param key="ADVANCED">
                                <param key="APPLY_HETEROTOPIC_SEARCH">no</param>
                                <param key="SELECT_ALL_SAMPLES_IN_TARGET">no</param>
                                <param key="MINIMUM_DISTANCE_BETWEEN_TWO_SELECTED_SAMPLES">no</param>
                                <param key="MINIMUM_DISTANCE_BETWEEN_TWO_SELECTED_SAMPLES_VALUE">0</param>
                                <param key="USE_MAXIMUM_SAMPLES">yes</param>
                                <param key="MAXIMUM_SAMPLES">$(par_estima_den[(par_estima_den.domain==dom_sect[j])&amp;(par_estima_den.setor==sect_den[k])].max_samples.iloc[0])</param>
                            </param>
                            <param key="DIVIDE_CODE">
                                <param key="OPTIMUM_NUMBER_OF_SAMPLES_PER_CODE">no</param>
                                <param key="OPTIMUM_NUMBER_OF_SAMPLES_PER_CODE_VALUE">1</param>
                                <param key="MAXIMUM_NUMBER_OF_SAMPLES_PER_CODE">no</param>
                                <param key="MAXIMUM_NUMBER_OF_SAMPLES_PER_CODE_VALUE">1</param>
                                <param key="USE_MINIMUM_NUMBER_OF_CODES">no</param>
                                <param key="MINIMUM_NUMBER_OF_CODES">1</param>
                                <param key="USE_MAXIMUM_NUMBER_OF_CODES">no</param>
                                <param key="MAXIMUM_NUMBER_OF_CODES">1</param>
                                <param key="CODE_VARIABLE"/>
                            </param>
                            <param key="SHORTCUTS">
                                <param key="MINIMUM_SAMPLES_ACTIVATED">yes</param>
                                <param key="MINIMUM_SAMPLES">$(par_estima_den[(par_estima_den.domain==dom_sect[j])&amp;(par_estima_den.setor==sect_den[k])].min_samples.iloc[0]))</param>
                                <param key="MAXIMUM_DISTANCE_WITHOUT_ANY_SAMPLE">no</param>
                                <param key="MAXIMUM_DISTANCE_WITHOUT_ANY_SAMPLE_VALUE">0</param>
