            <param key="TABLE_LIST"/>
            <param key="COMMANDS"/>
            <param key="OUTPUT_FOLDER">%public%/04_Estimation/02_Density</param>
            <param automatic="no" key="OUTPUT_PATTERN">Cross_%title_$(par_estima_den.domain[j])</param>
            <param key="EXPORT_GROUP">
                <param key="ENABLE">yes</param>
                <param key="OUTPUT_FORMAT">png</param>
                <param key="IMAGE_SIZE">SIZE_M</param>
                <param key="IMAGE_RATIO">RATIO_1_1</param>
            </param>
            <param key="EXPORT_GROUP_TABLE">
                <param key="ENABLE">yes</param>
                <param key="FORMAT">csv</param>
                <param key="SEPARATOR">COMMA</param>
                <param key="DECIMAL_SEPARATOR">DOT</param>
                <param key="UNDEF_STRING"/>
                <param key="EXCEL_NAME">Estimation Validation_DEN_$(par_estima_den.domain[j])_cross</param>
            </param>
            <param key="CHARTS_LAYOUTS"/>
            <param key="CHARTS_GROUP">
                <param key="STORE">no</param>
                <param key="STORE_GRAPHICS">yes</param>
                <param key="STORE_TABLES">no</param>
                <param key="NAME">%task</param>
            </param>
        </task>
        <task id="data-delete">
            <param key="LIST">
                <param key="ITEM_1">
                    <path>01_Dataset/04_Den</path>
                    <file>$(par_estima_den.database[0])</file>
                    <macroVar>den_sout_$(par_estima_den.domain[j])</macroVar>
                </param>
            </param>
        </task>
    </for>
    <comment>--- END ---</comment>
</batch>
