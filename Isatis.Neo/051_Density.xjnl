    <comment>#------ Estimativa ------#</comment>
    <for index="k" end="len(sect_den)-1" start="0">
        <python><![CDATA[print('Setores:',sectors)
print('N:',len(sectors))
dom_sect = par_estima_den[par_estima_den.setor==sectors[k]].domain.unique()
print('Dominios:',dom_sect)
print('N Dom:',len(dom_sect))
groups_sect = list(par_estima_den[par_estima_den.setor==sectors[k]].grupo)
print('Grupo:',groups_sect)
print('N Grupo:',len(groups_sect))]]></python>
        <for index="j" end="len(dom_sect)-1" start="0">
