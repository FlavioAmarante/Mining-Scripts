                                    <v3>$(par_estima_den[(par_estima_den.domain==dom_sect[j])&amp;(par_estima_den.setor==sect_den[k])].nested_W.iloc[0])/par_estima_den[(par_estima_den.domain==dom_sect[j])&amp;(par_estima_den.setor==sect_den[k])].W.iloc[0])</v3>
                                </param>
                                <param key="NESTED_MED_MINIMUM">$(par_estima_den[(par_estima_den.domain==dom_sect[j])&amp;(par_estima_den.setor==sect_den[k])].nested_min.iloc[0])</param>
