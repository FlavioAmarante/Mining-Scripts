                                    <dip>$(vario_den[(vario_den.grupo==groups_sect[j])&amp;(vario_den.setor==sect_den[k])].dip.iloc[0])</dip>
                                    <dipAzimuth>$(vario_den[(vario_den.grupo==groups_sect[j])&amp;(vario_den.setor==sect_den[k])].dipaz.iloc[0])</dipAzimuth>
