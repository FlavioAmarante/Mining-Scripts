        <param key="SCRIPT"><![CDATA[folder = app['project_path'] + "/public/04_Estimation/02_Density/"

df = calc.as_df()


# Calcula diferença entre SK e NN
df['OK_NN_dif'] = df['DENSITY'] - df['DEN_NN']
df['OK_NN_%'] = round(1- df['DENSITY']/df['DEN_NN'],2)*100

df_dif = round(df[df['DENSITY']>0].groupby('lito')[['DENSITY','DEN_NN','OK_NN_dif','OK_NN_%']].mean(),2)

# Summary ok vs nn
fig, ax = plt.subplots(figsize=(5, 2))  # Set the size of the figure
ax.axis('tight')
ax.axis('off')
df_dif.index.name = 'Lithology'
df_dif = df_dif.reset_index()
ax.table(cellText=df_dif.values, colLabels=df_dif.columns, loc='center')
#plt.title('Dif. OK vs NN')

# Save the table as an image file
plt.savefig(folder+'Den_OK_vs_NN_Diff.png', bbox_inches='tight', dpi=300)

# Boxplots
msk = sorted(list(df[df['lito'].isin($(lito_ore))]['lito'].unique()))
gst.boxplot_lito(df[df['lito'].isin($(lito_ore))],'OK_NN_dif','lito',msk,f'Den_OK_vs_NN_',folder)]]></param>
