        <param key="SCRIPT"><![CDATA[df = calc.as_df()

df['BREAK'] = 'NONE'
ma = (df['FLX_AN'].isin($(flx_3x)))
mb = (df['FLX_AN'].isin($(flx_4x)))
mc = (df['FEGL'].isna())
md = (df['FLX_AN'].isin($(flx_glb)))

df.loc[ma,'BREAK'] = '3FX'
df.loc[mb,'BREAK'] = '4FX'
df.loc[mc,'BREAK'] = 'NONE'
df.loc[md,'BREAK'] = 'GLB'

print('BREAK :')
print(df.groupby('BREAK')['BREAK'].count())

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
