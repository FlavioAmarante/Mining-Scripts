        <param key="SCRIPT"><![CDATA[df = calc.as_df()

df['STATUS_ISO'] = df['STATUS']

# Isotopizacao da Granulometria por NN
iso_gr = ['G1','G2','G3','G4']

# Isotopizacao por NN
df = gst.nn(df,'X','Y','X','CLI',iso_gr,'FEGL')

# Verifica heterotopia total

lst_hetv = ['FEGL','G1','FE1','G2','FE2','G3','FE3','G4','FE4']

gst.cvals(df[lst_hetv],'$(folder_fac)','FAC_iso_total')

# Substitui nulos dos analitos por teores globais.
tipos = ['FE', 'SI', 'P', 'AL', 'MN', 'PF', 'TI', 'MG', 'CA']
num_t = ['1','2','3','4']

for i in tipos:
    for j in num_t:
        mask = (df[i+'GL']>0) & (df[i+j].isna()) & (df['G'+j]>0)
        df.loc[mask, i+j] = df.loc[mask, i+'GL']
        mask2 = (df['G'+j]==0)
        df.loc[mask2, i+j] = np.nan
        mask3 = (df['G'+j].isna()) &(df['STATUS'].ne('OK'))
        df.loc[mask3, i+'GL'] = np.nan
            

gst.gra_count(df[df['CLI'].isin($(lito_ore))][$(lst_all)],'$(folder_fac)','FAC_isopia_total_end')

df = df.replace(np.nan,-99.00)
df.to_csv('$(folder_fac)' + '/fac_assay_iso_total_end.csv')
df = df.replace(-99.00, np.nan)


try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
