        <param key="SCRIPT"><![CDATA[
df = calc.as_df()

# Gera variável BREAK
msk2 = (df['FEGL']>0) & (df['CLI'].isin($(lito_ore)))
df['BREAK'] = 'NONE'
df.loc[msk2,'BREAK'] = 'FX'


try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
