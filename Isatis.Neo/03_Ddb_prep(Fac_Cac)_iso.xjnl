        <param key="SCRIPT"><![CDATA[folder_fac = app['project_path'] + "/public/01_Dataset/02_Fac"
folder_cac = app['project_path'] + "/public/01_Dataset/03_Cac"

df1 = pd.read_csv('$(folder_fac)' + '/fac_assay.csv')
df2 = pd.read_csv('$(folder_cac)' + '/cac_assay.csv')

'''
df1['COMP'] = df1['LENGTH']
df2['COMP'] = df2['LENGTH']

lst_val = ['FEGL', 'SIGL', 'PGL', 'ALGL', 'MNGL', 'PFGL', 'CAGL', 'MGGL', 'TIGL',
           'G1', 'G2', 'G3', 'G4',
           'FE1', 'SI1', 'P1', 'AL1', 'MN1', 'PF1', 'CA1', 'MG1', 'TI1',
           'FE2', 'SI2', 'P2', 'AL2', 'MN2', 'PF2', 'CA2', 'MG2', 'TI2',
           'FE3', 'SI3', 'P3', 'AL3', 'MN3', 'PF3', 'CA3', 'MG3', 'TI3', 
           'FE4', 'SI4', 'P4', 'AL4', 'MN4', 'PF4', 'CA4', 'MG4', 'TI4']


# Comparação FAC vs CAC
val_fac = df1[df1['CLI'].isin($(lito_ore))]
val_cac = df2[df2['CLI'].isin($(lito_ore))]

for i in lst_val:
    print('     ',i.upper())
    print('Litologias: ',$(lito_ore))
    print('FAC :',round(gst.cal_mp(val_fac,i, 'LENGTH'),7)  )
    print('CAC :',round(gst.cal_mp(val_cac,i, 'LENGTH'),7)  )
    print('Diff. Rela.:',round(((1-round(gst.cal_mp(val_cac,i, 'LENGTH'),7)/round(gst.cal_mp(val_fac,i, 'LENGTH'),7))*100),4),"%")
    print(' ')     


# Acc hist FAC vs CAC
for i in $(lst_glb):
    gst.gra_hist_cmp(df2,df1,i,'CLI','CLI',$(lito_ore),'$(folder_cac)',f'{i}_cac_vs_fac_',chart_size=[10,10])  
    
# Metragem
print(round(df2['LENGTH'].sum(),3))
print(round(df1['COMP'].sum(),3))
'''
# EDA
cac = df2

#Globais    
for i in $(lst_glb):
   gst.boxplot_lito(cac,i,'CLI',$(lito_ore), f'cac_{i}','$(folder_cac)')

# Histograma do ferro nas litologias mineralizadas
gst.hist_by_cat(cac[cac['CLI'].isin($(lito_ore))], 'CLI', 'FEGL', '$(folder_cac)', f'CAC: Histograma FEGL', figsize=(1000, 600))

# Pairplot Globais
gst.pairplot(cac,$(lst_glb),'CLI',$(lito_ore),'$(folder_cac)','cac_globais')

# Pairplot Globais
gst.pairplot(cac,$(lst_gs),'CLI',$(lito_ore),'$(folder_cac)','cac_grs')

# Correlação entre globais
gst.gra_mcorr(cac[$(lst_glb)], 'cac_glb','$(folder_cac)')

# Histogramas faixas e blobais
for i in $(cls_all):
    print('Histograma variáveis: ',i)
    gst.gra_lhist(cac,i,'CLI','$(folder_cac)',f'{i}_cac_fxs_',chart_size=[10,10]) 

# Metal Migration
gst.gra_scatter_grs(cac,'FEGL','FE1','G1','CLI',$(lito_ore),'$(folder_cac)','cac_fe_g1_fxs_',chart_size=[10,10]) 
gst.gra_scatter_grs(cac,'FEGL','FE2','G2','CLI',$(lito_ore),'$(folder_cac)','cac_fe_g2_fxs_',chart_size=[10,10])
gst.gra_scatter_grs(cac,'FEGL','FE3','G3','CLI',$(lito_ore),'$(folder_cac)','cac_fe_g3_fxs_',chart_size=[10,10])
gst.gra_scatter_grs(cac,'FEGL','FE3','G4','CLI',$(lito_ore),'$(folder_cac)','cac_fe_g4_fxs_',chart_size=[10,10])]]></param>
