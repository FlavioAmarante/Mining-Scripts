        <param key="SCRIPT"><![CDATA[df = calc.as_df()


for i in ['G1', 'G2', 'G3', 'G4']:
    print('Valores abaixo de 2% para',i,':',df[(df[i] > 0) & (df[i] < 2)][i].count())
    msk = (df[i] > 0) & (df[i] < 2)
    print('Valores abaixo de 2% por lito')
    print(df[msk].groupby('CLI')[i].count())


try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
