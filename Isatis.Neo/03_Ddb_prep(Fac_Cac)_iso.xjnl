        <param key="SCRIPT_START"><![CDATA[b = app['project_path'] + "/public/06_Scripts/py"
if b not in sys.path: sys.path.append(b)

c = app['project_path'] + "/public/06_Scripts/"
if c not in sys.path: sys.path.append(c)

import calc
import vale_gst_2024_v5 as gst
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd]]></param>
        <param key="SCRIPT"><![CDATA[df = calc.as_df()

msk2 = (df['FEGL']>0) & (df['CLI'].isin($(lito_ore))) & (df['G1'].notna() & df['G2'].notna() & df['G3'].notna() & df['G4'].notna())

df['BREAK'] = 'NONE'

df.loc[msk2,'BREAK'] = 'FX'

df = df.replace(np.nan,-99.00)
df.to_csv('$(folder_fac)' + '/fac_assay_prep_ini.csv')
df = df.replace(-99.00, np.nan)

# Acumula variaveis
df = gst.ddb_acc(df,'BREAK','FX')

df = df.replace(np.nan,-99.00)
df.to_csv('$(folder_fac)' + '/fac_assay_prep_acc.csv')
df = df.replace(-99.00, np.nan)

# Desacumula
df = gst.ddb_desac(df,'break','FX')

df = df.replace(np.nan,-99.00)
df.to_csv('$(folder_fac)' + '/fac_assay_prep_desacc.csv')
df = df.replace(-99.00, np.nan)

# Calcula Globais
df = gst.calc_glb(df,'break','FX',inplace=True)

df.to_csv('$(folder_fac)' + '/fac_assay_acc.csv')

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
    </task>
    <task id="calculator">
        <param key="DATA_TABLE">
            <param key="ROOT">
                <path>01_Dataset/02_Fac</path>
                <file>$(info[info.Parameters=='ddb_fac'].Variables.iloc[0])</file>
                <table>assay</table>
            </param>
            <param key="SELECTION"/>
