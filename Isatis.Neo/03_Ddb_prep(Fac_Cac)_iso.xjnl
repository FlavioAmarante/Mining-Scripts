column_list = df.columns.values.tolist()

for i in column_list:
  msk = (df[i]==0)
  df.loc[msk,i]= 0.010 

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
