import calc
import vale_gst_2024_v5 as gst
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd]]></param>
            <param key="SCRIPT"><![CDATA[df = calc.as_df()

gst.gra_count(df[$(lst_all)],'$(folder_fac)',f'FAC_historico_ini_')

# Tratamento dos dados históricos 3FX

#Regressão Linear Faixa 2
df1 = gst.linear_regression(df, 'G23', 'G2','G23',intercept=False)

#Regressão Linear Faixa 3
df2 = gst.linear_regression(df, 'G23', 'G3','G23',intercept=False)

df = df.replace(np.nan,-99.00)
df.to_csv('$(folder_fac)' + '/fac_assay_hist_v1.csv')
df = df.replace(-99.00, np.nan)

# Correção 3FX para 4FX
m1 = (df['$(var_tipo)']=='$(tipo)')
df.loc[m1,'G2'] = $(g2_reg) * df.loc[m1,'G23'] + $(interc)
df.loc[m1,'G3'] = df.loc[m1,'G23']-df.loc[m1,'G2']
m2 = (df['G3']<0)
df.loc[m2,'G3'] = 0

m2 = (df['G2']>0) & (df['$(var_tipo)']=='$(tipo)')
df.loc[m2,'FE2'] = (df.loc[m2,'FE23'])
df.loc[m2,'SI2'] = (df.loc[m2,'SI23'])
df.loc[m2,'P2']  = (df.loc[m2,'P23'] )
df.loc[m2,'AL2'] = (df.loc[m2,'AL23'])
df.loc[m2,'MN2'] = (df.loc[m2,'MN23'])
df.loc[m2,'PF2'] = (df.loc[m2,'PF23'])
df.loc[m2,'CA2'] = (df.loc[m2,'CA23'])
df.loc[m2,'MG2'] = (df.loc[m2,'MG23'])
df.loc[m2,'TI2'] = (df.loc[m2,'TI23'])

m3 = (df['G3']>0)  & (df['$(var_tipo)']=='$(tipo)')
df.loc[m3,'FE3']  = (df.loc[m3,'FE23'])
df.loc[m3,'SI3']  = (df.loc[m3,'SI23'])
df.loc[m3,'P3']   = (df.loc[m3,'P23'] )
df.loc[m3,'AL3']  = (df.loc[m3,'AL23'])
df.loc[m3,'MN3']  = (df.loc[m3,'MN23'])
df.loc[m3,'PF3']  = (df.loc[m3,'PF23'])
df.loc[m3,'CA3']  = (df.loc[m3,'CA23'])
df.loc[m3,'MG3']  = (df.loc[m3,'MG23'])
df.loc[m3,'TI3']  = (df.loc[m3,'TI23'])

df.loc[m1,'G23'] = np.nan   
df.loc[m1,'FE23']= np.nan
df.loc[m1,'SI23']= np.nan
df.loc[m1,'P23'] = np.nan
df.loc[m1,'AL23']= np.nan
df.loc[m1,'MN23']= np.nan
df.loc[m1,'PF23']= np.nan
df.loc[m1,'CA23']= np.nan
df.loc[m1,'MG23']= np.nan
df.loc[m1,'TI23']= np.nan

df = df.replace(np.nan,-99.00)
df.to_csv('$(folder_fac)' + '/fac_assay_hist_v2.csv')
df = df.replace(-99.00, np.nan)

df['brk'] = 'NONE'
md = (df['BREAK']=='3FX') | (df['BREAK']=='4FX') 
df.loc[md,'brk'] = 'FX'

# Calcula Globais
df = gst.calc_glb(df,'brk','FX',inplace=True)

gst.gra_count(df[$(lst_all)],'$(folder_fac)','FAC_historico_end')

df = df.replace(np.nan,-99.00)
df.to_csv('$(folder_fac)' + '/fac_assay_hist_end.csv')
df = df.replace(-99.00, np.nan)

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
