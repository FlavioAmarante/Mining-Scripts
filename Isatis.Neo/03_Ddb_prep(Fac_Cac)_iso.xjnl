        <param key="SCRIPT"><![CDATA[df = calc.as_df()

df_dif2 = df.groupby(['STATUS'])[['STATUS']].count()
print(df_dif2)

msk = (df['STATUS'].isin(['FQ']))
for i in $(lst_zera):
    df.loc[msk,i]=np.nan

df = df.replace(np.nan,-99.00)
df.to_csv('$(folder_fac)' + '/fac_assay_iso_end.csv')
df = df.replace(-99.00, np.nan)

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
        <param key="SCRIPT_END"/>
