        <param key="SCRIPT"><![CDATA[df = calc.as_df()

df = gst.linear_regression(df, 'FQGL', 'PFGL','FEGL',intercept=True)
df = gst.linear_regression(df, 'FQ1', 'PF1','FE1',intercept=True)
df = gst.linear_regression(df, 'FQ2', 'PF2','FE2',intercept=True)
df = gst.linear_regression(df, 'FQ3', 'PF3','FE3',intercept=True)
df = gst.linear_regression(df, 'FQ4', 'PF4','FE4',intercept=True)

gst.cvals(df[$(lst_glb)],'$(folder_fac)','FAC_PFGL_val_')

#Corrige PFGL = 0
msk = (df['FEGL']>0) & (df['PFGL'].isna())
df.loc[msk,'PFGL'] = 0.01

# Substitui nulos dos analitos por teores globais.
tipos = ['PF']
num_t = ['1','2','3','4']

for i in tipos:
    for j in num_t:
        mask = (df[i+'GL']>=-98) & (df[i+j].isna())
        df.loc[mask, i+j] = df.loc[mask, i+'GL']

# Corrige exedentes PF
listn = ['1','2','3','4']
varor = ['PF']

for i in listn:
  for j in varor:
    mn = (df[f'FE{i}'].isna())
    df.loc[mn,f'{j}{i}']=np.nan
    
column_list = ['PFGL','PF1','PF2','PF3','PF4']

for i in column_list:
  msk = (df[i]<0)
  df.loc[msk,i]= 0.01 
        
        
df.to_csv('$(folder_fac)' + '/fac_assay_pf.csv')

for v, d in info["vars"].items():
  locals()[v][:] = df[d["name"]]
  print(v, d["name"])]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
    </task>
