        <param key="SCRIPT"><![CDATA[df = calc.as_df()

df.replace(-99.00,np.nan, inplace=True)
df['FGRA'] = df[df['BREAK'] == 'FX'].apply(lambda r: r['G1']+r['G2']+r['G3']+r['G4'], axis=1)

for i in $(gra):
    print('Valores abaixo de 2% para',i,':',df[(df[i] > 0) & (df[i] < 2)][i].count())

# Desacumular após modificações na granulometria
df = gst.ddb_desac(df,'break','FX')

# Calcula Globais
df = gst.calc_glb(df,'break','FX',inplace=True)

df.to_csv('$(folder_cac)' + '/cac_assay_granulo.csv')


try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
    </task>
