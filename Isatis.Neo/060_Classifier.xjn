        <param key="SCRIPT"><![CDATA[
df = calc.as_df()

ind_ore = $(ind_ore)

# Aplica indicador
df['ore_pp'] = np.nan
mask = df['lito'].isin(ind_ore)
df.loc[mask,'ore_pp'] = 1

# Verica indicadores
df.groupby(['lito','ore_pp'])['ore_pp'].count()

for v, d in info["vars"].items():
  locals()[v][:] = df[d["name"]]
  print(v, d["name"])
