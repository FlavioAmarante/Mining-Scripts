                    <param key="ITEM_1"/>
                </param>
                <param key="USE_INTERVAL_DATA">no</param>
                <param key="USE_INTERVAL_SEPARATE_FILE">no</param>
                <param key="INTERVAL_DATA_TABLE">
                    <param key="ROOT">
                        <path>$(pasta_gra_ddb)</path>
                        <file>$(info[info.Parameters=='ddb_cac'].Variables.iloc[0])</file>
                        <table>Entry</table>
                    </param>
                    <param key="SELECTION"/>
                </param>
                <param key="INTERVAL_MIN_BOUNDS"/>
                <param key="INTERVAL_MAX_BOUNDS"/>
                <param key="INTERVAL_CONTEXT"/>
                <param key="INTERVAL_GEOSSET_PATTERN" automatic="yes">%gset-%context-withIntervalData</param>
                <param key="INTERVAL_FILE_PATTERN" automatic="yes">%file-%context-withIntervalData</param>
                <param key="INTERVAL_VAR_PATTERN" automatic="yes">%var-%context-%label</param>
                <param key="NUMBER_BURNIN_STEP" automatic="yes">10000</param>
                <param key="NUMBER_REALIZATION" automatic="yes">100</param>
                <param key="NUMBER_ITER_PER_REAL" automatic="yes">1000</param>
                <param key="SEED_NUMBER" automatic="yes">165426</param>
                <param key="BLOCK_SIZE_ROTATION">
                    <conv_id>1</conv_id>
                    <conv_string>+Z+Y+X</conv_string>
                    <a1>0</a1>
                    <a2>0</a2>
                    <a3>0</a3>
