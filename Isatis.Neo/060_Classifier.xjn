import calc
import vale_gst_v25_1 as gst
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd]]></param>
            <param key="SCRIPT"><![CDATA[folder = app['project_path'] + "/public/01_Dataset/02_Fac"

df = calc.as_df()


# Calculo do IR

mask1 = (df['lito'].isin($(lito_ore_ik)))  & (df['setor'] == '$(sect_ik[k])')

df.loc[mask1, 'ir'] = np.sqrt(((1 - df['ik'])**2) + ((df['ik_var'])**2))

for v, d in info["vars"].items():
  locals()[v][:] = df[d["name"]]
  print(v, d["name"])]]></param>
            <param key="SCRIPT_END"/>
            <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
