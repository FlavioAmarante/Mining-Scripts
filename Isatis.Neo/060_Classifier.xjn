        <param key="SCRIPT"><![CDATA[df = calc.as_df()

# Usar idxmax para encontrar o índice da coluna com o maior valor em cada linha
df['class-mw'] = df[['class-Prop-MW[medido]', 'class-Prop-MW[indicado]', 'class-Prop-MW[inferido]']].idxmax(axis=1)

# Mapear os nomes das colunas para as categorias desejadas
df['class-mw'] = df['class-mw'].map({
    'class-Prop-MW[medido]': 'medido',
    'class-Prop-MW[indicado]': 'indicado',
    'class-Prop-MW[inferido]': 'inferido'
})

# Trocar onde se for 'inferido' e tiver proporção de 'medido' maior que zero, a classe passa a ser 'indicado'
df.loc[(df['class-mw'] == 'inferido') & (df['class-Prop-MW[medido]'] > 0), 'class-mw'] = 'indicado'

v5[:] = df['class-mw']
  
]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
    </task>
