        <param key="SCRIPT"><![CDATA[df = calc.as_df()

m1 = (df['FEGL'] >= 0) & (df['lito'].isin($(lito_ore_ik))) & (df['ik']>=0)

med = (m1) & (df['dila']==1) & (df['ero']==0)
ind = (m1) & (df['dila']==2) & (df['ero']==0)
ind2 = (m1) & (df['dila']==1) & (df['ero']==1) 
inf = (m1) & (df['dila']==2) & (df['ero']==1) 
inf2 = (m1) & (df['dila']==0) & (df['ero']==1)
inf3 = (m1) & (df['dila']==3) & (df['ero']==1)
inf4 = (m1) & (df['dila']==0) & (df['ero']==0)
inf5 = (m1) & (df['dila']==3) & (df['ero']==0)

# Assigning class_malhan
df.loc[med, 'class_malhan'] = 1 
df.loc[ind, 'class_malhan'] = 2  
df.loc[ind2, 'class_malhan'] = 2
df.loc[inf, 'class_malhan'] = 3
df.loc[inf2, 'class_malhan'] = 3
df.loc[inf3, 'class_malhan'] = 3
df.loc[inf4, 'class_malhan'] = 3
df.loc[inf5, 'class_malhan'] = 3

# Assigning class_malha
df['class_malha'] = 'n'
df.loc[med,  'class_malha'] = 'medido' 
df.loc[ind,  'class_malha'] = 'indicado' 
df.loc[ind2, 'class_malha'] = 'indicado'
df.loc[inf,  'class_malha'] = 'inferido'
df.loc[inf2, 'class_malha'] = 'inferido'
df.loc[inf3, 'class_malha'] = 'inferido'
df.loc[inf4, 'class_malha'] = 'inferido'
df.loc[inf5, 'class_malha'] = 'inferido'


try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])
]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
    </task>
