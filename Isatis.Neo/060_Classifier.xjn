                    </param>
                </param>
                <param key="USE_LOCAL_NEIGHBORHOOD">yes</param>
                <param key="GROUP_LOCAL_NEIGHBORHOOD">
                    <param key="USE_SAME_PARAMS_AS_VMODEL">no</param>
                    <param key="USE_ROTATION">yes</param>
                    <param key="GROUP_NEIGH_ROTATION">
