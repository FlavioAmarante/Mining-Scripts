                                <param key="VALUE">$(vario_ik[vario_ik.setor==sect_ik[k]].w1.iloc[0])</param>
                                <param key="LOWER_BOUND">1e-10</param>
                                <param key="UPPER_BOUND">1e-10</param>
                            </param>
                        </param>
                        <param key="ANISOTROPY_ORIENTATION" automatic="no">
