        <param key="SCRIPT"><![CDATA[folder = app['project_path'] + "/public/04_Estimation/03_Class"

df = calc.as_df()

medc=(df['class']=='medido')
medindc=((df['class']=='indicado')|(df['class']=='medido'))
notnc=(df['class']!='n')

df['med']=0.0001
df['med_ind']=0.0001
df['not_n']=0.0001
df.loc[medc,'med']=1
df.loc[medindc,'med_ind']=1
df.loc[notnc,'not_n']=1

for v, d in info["vars"].items():
  locals()[v][:] = df[d["name"]]
  print(v, d["name"])]]></param>
