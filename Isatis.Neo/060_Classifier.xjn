            <param key="SCRIPT"><![CDATA[folder = app['project_path'] + "/public/04_Estimation/03_Class"

df = calc.as_df()

inf = (df['ik']>=-98) & (df['FEGL']>=-98) & (df['lito'].isin($(lito_ore_ik))) & (df['setor'] == '$(sect_ik[k])')
ind = (inf) & (df['ir']>=$(par_estima_ik[par_estima_ik.setor==sect_ik[k]].LI.iloc[0])) & (df['ir']<$(par_estima_ik[par_estima_ik.setor==sect_ik[k]].LS.iloc[0]))
med = (inf) & (df['ir']>=0) & (df['ir']<$(par_estima_ik[par_estima_ik.setor==sect_ik[k]].LI.iloc[0]))
ind2 = (med) & (df['FEGL-NbNeigh']<2)
n = (df['setor'] == '$(sect_ik[k])')

df.loc[inf, 'classn'] = 3
df.loc[ind, 'classn'] = 2
df.loc[med, 'classn'] = 1
df.loc[ind2, 'classn'] = 2

df.loc[n,'class'] = 'n'
df.loc[inf, 'class'] = 'inferido'
df.loc[ind, 'class'] = 'indicado'
df.loc[med, 'class'] = 'medido'
df.loc[ind2, 'class'] = 'indicado'

        
for v, d in info["vars"].items():
  locals()[v][:] = df[d["name"]]
  print(v, d["name"])]]></param>
            <param key="SCRIPT_END"/>
            <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
        </task>
