        <param key="SCRIPT"><![CDATA[
df = calc.as_df()

m1 = (df['FEGL'] >= 0) & (df['lito'].isin($(lito_ore_ik))) & (df['ik']>=0)

df['class_mw2'] = 'n'

m2 = m1 & (df['med-Mean-MW'] >= 0.5)
df.loc[m2,'class_mw2'] = 'medido' 

m3 = m1 & (df['med_ind-Mean-MW'] >= 0.5) & (df['class_mw2'] == 'n')
df.loc[m3,'class_mw2'] = 'indicado' 

m4 = m1 & (df['not_n-Mean-MW'] >= 0.5) & (df['class_mw2'] == 'n')
df.loc[m4,'class_mw2'] = 'inferido'  

'''
v5 = 'n'
if (v2 >= 0.5) and (v1 > -1):
  v5 = 'medido' 
  
elif (v3 >= 0.5) and (v1 > -1):
  v5 = 'indicado' 
  
elif (v4 >= 0.5) and (v1 > -1):
  v5 = 'inferido' 
  '''
  
try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])

]]></param>
