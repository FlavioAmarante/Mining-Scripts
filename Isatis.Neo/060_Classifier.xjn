c = app['project_path'] + "/public/06_Scripts/"
if c not in sys.path: sys.path.append(c)

import calc
import vale_gst_v25_1 as gst
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd]]></param>
        <param key="SCRIPT"><![CDATA[folder = app['project_path'] + "/public/01_Dataset/02_Fac"

df = calc.as_df()

ind_ore = $(ind_ore)
ind_zero = $(ind_zero)

# Aplica indicador
df['ik'] = np.nan
mask = df['CLI'].isin(ind_ore)
df.loc[mask,'ik'] = 1
mask2 = df['CLI'].isin(ind_zero)
df.loc[mask2,'ik'] = 0.0001

# Verica indicadores
df.groupby(['CLI','ik'])['ik'].count()

for v, d in info["vars"].items():
  locals()[v][:] = df[d["name"]]
  print(v, d["name"])]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
