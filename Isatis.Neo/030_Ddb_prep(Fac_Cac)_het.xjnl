        <param key="SCRIPT"><![CDATA[folder_fac = app['project_path'] + "/public/01_Dataset/02_Fac"
folder_cac = app['project_path'] + "/public/01_Dataset/03_Cac"

df1 = pd.read_csv('$(folder_fac)' + '/fac_assay.csv')
df2 = pd.read_csv('$(folder_cac)' + '/cac_assay.csv')

# EDA
cac = df2

#Globais    
for i in $(lst_glb):
   gst.boxplot_lito(cac,i,'CLI',$(lito_ore), f'cac_{i}','$(folder_cac)')

# Pairplot Globais
gst.pairplot(cac,$(lst_glb),'CLI',$(lito_ore),'$(folder_cac)','cac_globais')

# Pairplot Globais
gst.pairplot(cac,$(lst_gs),'CLI',$(lito_ore),'$(folder_cac)','cac_grs')

# Correlação entre globais
gst.gra_mcorr(cac[$(lst_glb)], 'cac_glb','$(folder_cac)')

# Histogramas faixas e blobais
for i in $(cls_all):
    print('Histograma variáveis: ',i)
    gst.gra_lhist(cac,i,'CLI','$(folder_cac)',f'{i}_cac_fxs_',chart_size=[10,10]) 

# Metal Migration
gst.gra_scatter_grs(cac,'FEGL','FE1','G1','CLI',$(lito_ore),'$(folder_cac)','cac_fe_g1_fxs_',chart_size=[10,10]) 
gst.gra_scatter_grs(cac,'FEGL','FE2','G2','CLI',$(lito_ore),'$(folder_cac)','cac_fe_g2_fxs_',chart_size=[10,10])
gst.gra_scatter_grs(cac,'FEGL','FE3','G3','CLI',$(lito_ore),'$(folder_cac)','cac_fe_g3_fxs_',chart_size=[10,10])
gst.gra_scatter_grs(cac,'FEGL','FE3','G4','CLI',$(lito_ore),'$(folder_cac)','cac_fe_g4_fxs_',chart_size=[10,10])]]></param>
