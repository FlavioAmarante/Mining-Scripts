                <param key="SCRIPT_START"><![CDATA[b = app['project_path'] + "/public/06_Scripts/py"
if b not in sys.path: sys.path.append(b)

c = app['project_path'] + "/public/06_Scripts/"
if c not in sys.path: sys.path.append(c)

import calc
import vale_gst_v25_1 as gst
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd
import plotly ]]></param>
                <param key="SCRIPT"><![CDATA[df = calc.as_df()


#AL
m1 = (df['AL$(varn[i])'].isna()) & (df['FE$(varn[i])']>0)
df.loc[m1,'AL$(varn[i])']=df.loc[m1,'AL$(varn[i])-Q']

#CA
m1 = (df['CA$(varn[i])'].isna()) & (df['FE$(varn[i])']>0)
df.loc[m1,'CA$(varn[i])']=df.loc[m1,'CA$(varn[i])-Q']

#MG
m1 = (df['MG$(varn[i])'].isna()) & (df['FE$(varn[i])']>0)
df.loc[m1,'MG$(varn[i])']=df.loc[m1,'MG$(varn[i])-Q']


#MN
m1 = (df['MN$(varn[i])'].isna()) & (df['FE$(varn[i])']>0)
df.loc[m1,'MN$(varn[i])']=df.loc[m1,'MN$(varn[i])-Q']

#P
m1 = (df['P$(varn[i])'].isna()) & (df['FE$(varn[i])']>0)
df.loc[m1,'P$(varn[i])']=df.loc[m1,'P$(varn[i])-Q']

#Ti
m1 = (df['TI$(varn[i])'].isna()) & (df['FE$(varn[i])']>0)
df.loc[m1,'TI$(varn[i])']=df.loc[m1,'TI$(varn[i])-Q']

#FE3O4
m1 = (df['FE3O4_$(varn[i])'].isna()) & (df['FE$(varn[i])']>0)
df.loc[m1,'FE3O4_$(varn[i])']=df.loc[m1,'FE3O4_$(varn[i])-Q']



try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])
]]></param>
                <param key="SCRIPT_END"/>
                <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
