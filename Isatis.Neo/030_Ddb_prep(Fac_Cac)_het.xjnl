        <param key="SCRIPT"><![CDATA[df = calc.as_df()

m1 = (df['FE3O4_GL'].isna()) & (df['FOGL'].notna()) & (df['FEGL']>0)
df.loc[m1,'FE3O4_GL'] = round(df.loc[m1,'FOGL'] / 0.3103,3)
m1 = (df['FEGL'].isna())
df.loc[m1,'FE3O4_GL'] = np.nan

m2 = (df['FE3O4_1'].isna()) & (df['FO1'].notna()) & (df['FE1']>0)
df.loc[m2,'FE3O4_1'] = round(df.loc[m2,'FO1'] / 0.3103,3)
m2 = (df['FE1'].isna())
df.loc[m2,'FE3O4_1'] = np.nan

m3 = (df['FE3O4_2'].isna()) & (df['FO2'].notna()) & (df['FE2']>0)
df.loc[m3,'FE3O4_2'] = round(df.loc[m3,'FO2'] / 0.3103,3)
m3 = (df['FE2'].isna())
df.loc[m3,'FE3O4_2'] = np.nan

m4= (df['FE3O4_3'].isna()) & (df['FO3'].notna()) & (df['FE3']>0)
df.loc[m4,'FE3O4_3'] = round(df.loc[m4,'FO3'] / 0.3103,3)
m4 = (df['FE3'].isna())
df.loc[m4,'FE3O4_3'] = np.nan

m5 = (df['FE3O4_4'].isna()) & (df['FO4'].notna()) & (df['FE4']>0)
df.loc[m5,'FE3O4_4'] = round(df.loc[m5,'FO4'] / 0.3103,3)
m5 = (df['FE4'].isna())
df.loc[m5,'FE3O4_4'] = np.nan

