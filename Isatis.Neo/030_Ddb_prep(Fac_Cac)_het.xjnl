import numpy as np
import pandas as pd]]></param>
            <param key="SCRIPT"><![CDATA[df = calc.as_df()

tipo = ['23']
for i in tipo:
  df[f'FQ{i}-PF{i}'] = (100 - (df[f'FQ{i}']))
  msk = (df[f'PF{i}']>-98)
  df.loc[msk,f'FQ{i}-PF{i}'] = (100 - (df.loc[msk,f'FQ{i}']- df.loc[msk,f'PF{i}']))
  df = gst.linear_regression(df, f'FQ{i}-PF{i}', f'PF{i}',f'FE{i}',intercept=True)

gst.cvals(df[$(lst_glb)],'$(folder_fac)','FAC_PFGL_val_')

# Substitui nulos dos analitos por teores globais.
tipos = ['PF']
num_t = ['23']

for i in tipos:
    for j in num_t:
        mask = (df[i+'GL']>=-98) & (df[i+j].isna())
        df.loc[mask, i+j] = df.loc[mask, i+'GL']

# Corrige exedentes PF
listn = ['23']
varor = ['PF']

for i in listn:
  for j in varor:
    mn = (df[f'FE{i}'].isna())
    df.loc[mn,f'{j}{i}']=np.nan  

column_list = ['PF23']

for i in column_list:
  msk = (df[i]<0)
  df.loc[msk,i]= 0.01 

df.to_csv('$(folder_fac)' + '/fac_assay_pf23.csv')


try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
            <param key="SCRIPT_END"/>
            <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
        </task>
