    <comment>--- MW Mediana Variaveis principais ---</comment>
    <for index="x" end="len(lito_un)-1" start="0">
        <for index="i" end="len(varn)-1" start="0">
            <task id="create-macro_selection-from-rules" version="2">
                <param key="DATASET">
                    <param key="ROOT">
                        <path>01_Dataset/02_Fac</path>
                        <file>$(info[info.Parameters=='ddb_fac'].Variables.iloc[0])</file>
                        <table>assay</table>
                    </param>
                    <param key="OUT_CATEGORICAL">
                        <macroVar>$(lito_un[x])_FE$(varn[i])>0</macroVar>
                    </param>
                    <param key="RULES">
                        <param key="VARIABLES">
                            <param key="ITEM_1">
