        <param key="SCRIPT_START"><![CDATA[b = app['project_path'] + "/public/06_Scripts/py"
if b not in sys.path: sys.path.append(b)

c = app['project_path'] + "/public/06_Scripts/"
if c not in sys.path: sys.path.append(c)

import calc
import vale_gst_v25_1 as gst
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd]]></param>
        <param key="SCRIPT"><![CDATA[
df = calc.as_df()

#---- G2<2% ---

a1 = '2'
a2 = '3'

msk = (df[f'G{a1}']>0) & (df[f'G{a1}']<2) & (df['BREAK'] == 'FX')

df.loc[msk,f'G{a2}'] = df.loc[msk,f'G{a2}']+df.loc[msk,f'G{a1}']
df.loc[msk,f'G{a1}'] = 0 


for i in $(varor):	
	df.loc[msk,f'A{i}{a2}'] = df.loc[msk,f'A{i}{a2}']+df.loc[msk,f'A{i}{a1}']
	df.loc[msk,f'A{i}{a1}'] = 0


df = df.replace(-99.00, np.nan)

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
