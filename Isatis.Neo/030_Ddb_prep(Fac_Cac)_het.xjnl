        <param key="SCRIPT_START"><![CDATA[b = app['project_path'] + "/public/06_Scripts/py"
if b not in sys.path: sys.path.append(b)

c = app['project_path'] + "/public/06_Scripts/"
if c not in sys.path: sys.path.append(c)

import calc
import vale_gst_v25_1 as gst
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd]]></param>
        <param key="SCRIPT"><![CDATA[df = calc.as_df()

# Zera Fechamentos
df['FQ1'] = np.nan
df['FQ2'] = np.nan
df['FQ3'] = np.nan
df['FQ4'] = np.nan
df['FQGL'] = np.nan
df['FGRA'] = np.nan

# Recalcular fechamento químico Faixas
df = gst.calc_fechaq_glb(df,'BREAK','GLB',inplace=True)

# Recalcular fechamento químico Faixas
df = gst.calc_fechaq(df,'BREAK','FX',inplace=True)

# Recalcular fechamento granulométrico
mgra = (df['BREAK']=='FX')
df.loc[mgra,'FGRA'] = np.nan
df.loc[mgra,'FGRA'] = df.loc[mgra,'G1'].fillna(0)+df.loc[mgra,'G2'].fillna(0)+df.loc[mgra,'G3'].fillna(0)+df.loc[mgra,'G4'].fillna(0)


# Gera variáveis check fechamento
df['CK_FQGL'] =  df.apply(lambda r: 1 if ((r['FQGL'] > 0) and (95 <= r['FQGL'] <= 104) or np.isnan(r['FQGL'])) else 0, axis=1)
df['CK_FQ1']  =  df.apply(lambda r: 1 if ((r['FQ1'] > 0) and (95 <= r['FQ1'] <= 104) or np.isnan(r['FQ1'])) else 0, axis=1)
df['CK_FQ2']  =  df.apply(lambda r: 1 if ((r['FQ2'] > 0) and (95 <= r['FQ2'] <= 104) or np.isnan(r['FQ2'])) else 0, axis=1)
df['CK_FQ3']  =  df.apply(lambda r: 1 if ((r['FQ3'] > 0) and (95 <= r['FQ3'] <= 104) or np.isnan(r['FQ3'])) else 0, axis=1)
df['CK_FQ4']  =  df.apply(lambda r: 1 if ((r['FQ4'] > 0) and (95 <= r['FQ4'] <= 104) or np.isnan(r['FQ4'])) else 0, axis=1)
df['CK_FGRA']  =  df.apply(lambda r: 1 if ((r['FGRA'] > 0) and (99 <= r['FGRA'] <= 101) or np.isnan(r['FGRA'])) else 0, axis=1)

# Check final
df['CK_FQ'] = df.apply(lambda r: 'OK' if (r['CK_FQGL']==1 and r['CK_FQ1']==1 and r['CK_FQ2']==1 and r['CK_FQ3']==1 and r['CK_FQ4']==1 and r['CK_FGRA']==1) else 'ERRO', axis=1)
mfq1 = (df['G1']==0)&(df['CK_FQGL']==1)&(df['CK_FQ2']==1)&(df['CK_FQ3']==1)&(df['CK_FQ4']==1)&(df['CK_FGRA']==1)
df.loc[mfq1,'CK_FQ']='OK'
mfq2 = (df['G2']==0)&(df['CK_FQGL']==1)&(df['CK_FQ1']==1)&(df['CK_FQ3']==1)&(df['CK_FQ4']==1)&(df['CK_FGRA']==1)
df.loc[mfq2,'CK_FQ']='OK'
mfq3 = (df['G3']==0)&(df['CK_FQGL']==1)&(df['CK_FQ1']==1)&(df['CK_FQ2']==1)&(df['CK_FQ4']==1)&(df['CK_FGRA']==1)
df.loc[mfq3,'CK_FQ']='OK'
mfq4 = (df['G4']==0)&(df['CK_FQGL']==1)&(df['CK_FQ1']==1)&(df['CK_FQ2']==1)&(df['CK_FQ3']==1)&(df['CK_FGRA']==1)
df.loc[mfq4,'CK_FQ']='OK'

#Zera FQ
mfq = (df['STATUS'] == 'FQ')
df.loc[mfq,'STATUS'] = 'OK'

# Amostras erro análise química
m6 = (df['CK_FQ']=='ERRO') & (df['STATUS']=='OK')
df.loc[m6,'STATUS'] = 'FQ'

m7 = (df['BREAK']=='GLB') & (df['CK_FQGL']==0)
df.loc[m7,'STATUS'] = 'FQ'

df_dif2 = df.groupby(['STATUS'])[['STATUS']].count()
print(df_dif2)


df = df.replace(-99.00, np.nan)

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
