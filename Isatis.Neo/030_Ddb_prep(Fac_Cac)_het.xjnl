        <param key="SCRIPT_START"><![CDATA[b = app['project_path'] + "/public/06_Scripts/py"
if b not in sys.path: sys.path.append(b)

c = app['project_path'] + "/public/06_Scripts/"
if c not in sys.path: sys.path.append(c)

import calc
import vale_gst_v25_1 as gst
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd]]></param>
        <param key="SCRIPT"><![CDATA[
df = calc.as_df()

#---- Normaliza ---

df['ax_g1'] = np.nan
df['ax_g2'] = np.nan
df['ax_g3'] = np.nan
df['ax_g4'] = np.nan

msk = (df['BREAK']=='FX') 

df.loc[msk,'FGRA'] = np.nan
df.loc[msk,'FGRA'] = df.loc[msk,'G1'].fillna(0)+df.loc[msk,'G2'].fillna(0)+df.loc[msk,'G3'].fillna(0)+df.loc[msk,'G4'].fillna(0)

df.loc[msk,'ax_g1'] = 100*(df.loc[msk,'G1']/df.loc[msk,'FGRA'])
df.loc[msk,'ax_g2'] = 100*(df.loc[msk,'G2']/df.loc[msk,'FGRA'])
df.loc[msk,'ax_g3'] = 100*(df.loc[msk,'G3']/df.loc[msk,'FGRA'])
df.loc[msk,'ax_g4'] = 100*(df.loc[msk,'G4']/df.loc[msk,'FGRA'])


df['G1']=df['ax_g1'] 
df['G2']=df['ax_g2'] 
df['G3']=df['ax_g3'] 
df['G4']=df['ax_g4'] 


df = df.replace(-99.00, np.nan)

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
    </task>
