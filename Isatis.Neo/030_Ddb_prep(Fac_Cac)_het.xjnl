import matplotlib.pyplot as plt
import numpy as np
import pandas as pd]]></param>
        <param key="SCRIPT"><![CDATA[df = calc.as_df()

df['BREAK'] = 'NONE'

# Gera variável BREAK
ma = (df['G1'].isna()) & (df['FEGL']>0) & (df['CLI'].isin(['HF', 'IF', 'IC', 'HCT', 'ICT', 'IDO', 'HMN', 'IMN', 'FMN', 'HC', 'CG']))
df.loc[ma,'BREAK'] = 'GLB'

ma = (df['G1']>=0) & (df['FEGL']>0) & (df['CLI'].isin(['HF', 'IF', 'IC', 'HCT', 'ICT', 'IDO', 'HMN', 'IMN', 'FMN', 'HC', 'CG']))
df.loc[ma,'BREAK'] = 'FX'


df = df.replace(-99.00, np.nan)

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
