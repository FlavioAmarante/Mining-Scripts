import pandas as pd]]></param>
        <param key="SCRIPT"><![CDATA[df = calc.as_df()

# Adiciona variaveis auxiliares
df['STATUS']='OK'
df['OBS']='Amostras validas'

# Classifica amostras do banco de dados
# Amostras sem análise química
m1 = (df['FEGL'].isna()) 
df.loc[m1,'STATUS'] = $(remv_lst)[0]
df.loc[m1,'OBS'] = $(remv)[$(remv_lst)[0]]

# Amostras sem granulometria
m3 = (df['G1'].isna()) & (df['FEGL']>0) & (df['STATUS']=='OK')
df.loc[m3,'STATUS'] = $(remv_lst)[2]
df.loc[m3,'OBS'] = $(remv)[$(remv_lst)[2]]

# Amostras de litologias estéreis
m2 = (~df['CLI'].isin($(lito_ore_upper))) & (df['FEGL']>0) & (df['STATUS']=='OK')
df.loc[m2,'STATUS'] = $(remv_lst)[1]
df.loc[m2,'OBS'] = $(remv)[$(remv_lst)[1]]

# Amostras sem recuperação
m4 = ((df['REC']>0) & (df['REC']<60)) | (df['CLI']=='DT' ) | (df['CLI']=='SR') & (df['FEGL']>0) & (df['STATUS']=='OK')
df.loc[m4,'STATUS'] = $(remv_lst)[3]
df.loc[m4,'OBS'] = $(remv)[$(remv_lst)[3]]

# Amostras de com não conformidades QA|QC
m5 = (df['NA'].isin($(qaqc_nc['Amostra'].tolist()))) & (df['STATUS']=='OK')
df.loc[m5,'STATUS'] = $(remv_lst)[4]
df.loc[m5,'OBS'] = $(remv)[$(remv_lst)[4]]

df_dif = df.groupby(['STATUS','OBS'])['COMP'].count()

# Status DDB
fig, ax = plt.subplots(figsize=(6, 2))  # Set the size of the figure
ax.axis('tight')
ax.axis('off')
df_dif.index.name = 'STATUS'
df_dif = df_dif.reset_index()
ax.table(cellText=df_dif.values, colLabels=df_dif.columns, loc='center')

# Save the table as an image file
plt.savefig('$(folder_fac)'+'/FSO_val.png', bbox_inches='tight', dpi=300)

# Check visual da distribuicao dos dados 
gst.gra_disp($(lst_all),df,'$(folder_fac)','DDB_heterotopia')

# Verifica Heterotopia
for i in range(len($(lst_of_lsts))):
    gst.cvals(df[$(lst_of_lsts)[i]],'$(folder_fac)',f'FAC_Heterotopy_')]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
    </task>
