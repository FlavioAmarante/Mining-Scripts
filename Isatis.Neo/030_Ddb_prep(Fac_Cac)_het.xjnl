        <param key="SCRIPT"><![CDATA[
df = calc.as_df()

df1 = pd.read_csv('$(folder_fac)' + '/fac_assay.csv')
df1['COMP'] = df1['LENGTH']
df1 = df1.replace(-99.00, np.nan)

# EDA
fac = df1

#Globais    
for i in $(lst_glb):
    gst.boxplot_lito(fac,i,'CLI',$(lito_ore), f'fac_{i}','$(folder_fac)')

# Histograma do ferro nas litologias mineralizadas
gst.hist_by_cat(fac[fac['CLI'].isin($(lito_ore))], 'CLI', 'FEGL', '$(folder_fac)', f'fac: Histograma FEGL', figsize=(1000, 600))

# Pairplot Globais
gst.pairplot(fac,$(lst_glb),'CLI',$(lito_ore),'$(folder_fac)','fac_globais')

# Pairplot Globais
gst.pairplot(fac,$(lst_gs),'CLI',$(lito_ore),'$(folder_fac)','fac_grs')

# Correlação entre globais
gst.gra_mcorr(fac[$(lst_glb)], 'fac_glb','$(folder_fac)')

# Histogramas faixas e blobais
for i in $(cls_all):
    print('Histograma variáveis: ',i)
    gst.gra_lhist(fac,i,'CLI','$(folder_fac)',f'{i}_fac_fxs_',chart_size=[10,10]) 

# Metal Migration
gst.gra_scatter_grs(fac,'FEGL','FE1','G1','CLI',$(lito_ore),'$(folder_fac)','fac_fe_g1_fxs_',chart_size=[10,10]) 
gst.gra_scatter_grs(fac,'FEGL','FE2','G2','CLI',$(lito_ore),'$(folder_fac)','fac_fe_g2_fxs_',chart_size=[10,10])
gst.gra_scatter_grs(fac,'FEGL','FE3','G3','CLI',$(lito_ore),'$(folder_fac)','fac_fe_g3_fxs_',chart_size=[10,10])
gst.gra_scatter_grs(fac,'FEGL','FE3','G4','CLI',$(lito_ore),'$(folder_fac)','fac_fe_g4_fxs_',chart_size=[10,10])

# Localização Amostras 
fig = px.scatter(round(fac,2), x="X", y="Y", color='FEGL',width=750, height=750)
fig.update_layout(title_text='Distribuicao Espacial fac', title_font=dict(size=20))
fig.write_html('{}/{}_loc.html'.format('$(folder_fac)','fac_Localiza'))]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
    </task>
