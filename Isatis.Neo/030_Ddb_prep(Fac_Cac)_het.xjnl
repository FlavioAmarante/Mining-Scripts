        <param key="SCRIPT"><![CDATA[df = calc.as_df()

# Acumula variaveis
df = gst.ddb_acc(df,'BRKEST','FX')

# Desacumula
df = gst.ddb_desac(df,'brkest','FX')

# Calcula Globais
df = gst.calc_glb(df,'brkest','FX',inplace=True)


df = df.replace(-99.00, np.nan)

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
