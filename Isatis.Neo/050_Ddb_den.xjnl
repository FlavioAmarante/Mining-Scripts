        <param key="SCRIPT"><![CDATA[# Import Pastas
public_path = Path(app['project_public_path'])

df = calc.as_df()

outden = pd.read_excel(public_path / "par.xlsx", sheet_name = 'out_den')

# Initialize OUT column
df['OUT'] = 0

# Get unique values for variable and lito
unique_variables = list(outden['variable'].unique())
unique_litos = list(outden['lito'].unique())

# Loop through unique variables and litos
for k in unique_litos:
    for i in unique_variables:
      m1 = (outden['lito'] == k) & (outden['variable'] == i)
      if len(list(outden[m1]['inf_limit']))> 0:
        msk = (df['CLI'] == k) & ((df[i] < float(outden[m1]['inf_limit']))|(df[i] > float(outden[m1]['sup_limit'])))
        df.loc[msk, 'OUT'] = 1   

# Retorno variáveis
try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
