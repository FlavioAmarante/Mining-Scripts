    <comment>--- Suporte Dados ---</comment>
    <python><![CDATA[import pandas as pd
import numpy as np

def change_support_in_csv(input_csv, output_csv, support):
    """
    Function to read CSV, change support size, and export to new CSV.
    """
    df = pd.read_csv(input_csv)
    print(df.head())
    
    # -99 to Nan
    df.replace(-99.00, np.nan, inplace=True)
    
    # Change support size
    df['DEPT_RL'] = (df['DEPT'] // support) * support
    
    # Format DEPT_RL to two decimal places
    df['DEPT_RL'] = df['DEPT_RL'].map(lambda x: f"{x:.2f}")
    
    # Concatenate FURO and DEPT_RL into a categorical variable
    df['DEPT_FURO'] = df['FURO'].astype(str) + '_' + df['DEPT_RL'].astype(str)  

    # Select only numeric columns for grouping
    numeric_cols = df.select_dtypes(include='number').columns.tolist()

    # Group by DEPT_FURO and calculate the mean for each group
    df_grouped = df.groupby(['DEPT_FURO'])[numeric_cols].mean().reset_index()

    # Split DEPT_FURO back into FURO and FROM for sorting
    df_grouped[['FURO', 'DE']] = df_grouped['DEPT_FURO'].str.split('_', expand=True)
      
    df_grouped['DE'] = df_grouped['DE'].astype(float) 
    df_grouped['ATE'] = df_grouped['DE']+ support
    
    # Sort by FURO and DEPT_RL
    df_grouped.sort_values(by=['FURO', 'DE'], inplace=True)
    
    # Reorder columns
    columns_order = ['FURO', 'DE', 'ATE', 'DEPT', 'DENB', 'OHS3', 'OHSD', 'ST', 'END'] #'WL',
    df_grouped = df_grouped[columns_order]
    
    # Replace NaN values with -99.00
    df_grouped.replace(np.nan, -99.00, inplace=True)
    
    # Export to CSV
    df_grouped.to_csv(output_csv, index=False)
    

    
    return df_grouped


# Suporte selecionado 
sup = 0.2

#Arquivo entrada
file_las_csv = '$(folder_dendb)'+'/'+'$(info[info.Parameters=='projeto'].Variables.iloc[0])'+'_join_las.csv'

# Nome do arquivo de saída CSV final
final_csv = '$(folder_dendb)'+'/'+'$(info[info.Parameters=='projeto'].Variables.iloc[0])'+'_las_sup.csv'

# Ler o CSV integrado e fazer a mudança de suporte no CSV
change_support_in_csv(file_las_csv, final_csv, sup)

print(f"Processamento concluído e dados exportados para {final_csv}")
]]></python>
