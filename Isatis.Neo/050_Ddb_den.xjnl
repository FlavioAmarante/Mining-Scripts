    <comment>--- Junção Gama-gama e Convencionais ---</comment>
    <python><![CDATA[import pandas as pd
import numpy as np
from pathlib import Path

# Import Pastas
public_path = Path(app['project_public_path'])

ddb_den_conv = public_path /r'01_Dataset/04_Den/$(info[info.Parameters=='ddb_conv'].Variables.iloc[0]).csv'
ddb_den_ggr = public_path /r'01_Dataset/04_Den/$(info[info.Parameters=='ddb_gama_raso'].Variables.iloc[0]).csv'
ddb_den_gama  = public_path /r'01_Dataset/04_Den/$(info[info.Parameters=='ddb_gama'].Variables.iloc[0])_ddh.csv'

# Carrega banco de dados
den_conv = pd.read_csv(ddb_den_conv)
den_conv.columns = den_conv.columns.str.upper()
den_conv['TP'] = 'CV'

den_ggr = pd.read_csv(ddb_den_ggr)
den_ggr.columns = den_ggr.columns.str.upper()
den_ggr['TP'] = 'GR'

den_gama = pd.read_csv(ddb_den_gama)
den_gama.columns = den_gama.columns.str.upper()
den_gama['TP'] = 'GG'

column_name_mapping = {
        'holeid': ['dhid','DHID','furo','FURO','HOLE ID','hole id','HOLEID','holeid','Name','name'],
        'na':['NA','samplena','sample_same','Amostra','AMOSTRA'],
        'mid_x': ['LESTE','MIDX','X','x','midx','ESTE'],
        'mid_y': ['NORTE','MIDY','Y','y','midy'],
        'mid_z': ['COTA','MIDZ','Z','z','midz','COTA'],
        'comp': ['length', 'LENGTH','len','COMP','Length'],
        'cli': ['geocod', 'CLI'],
        'density': ['DENSIDADE', 'Densidade','OHSD','ohsd','density','densidade'],
        'dens_s': ['DENS_SECA', 'Dens_Seca', 'dens_seca'],
        'denb': ['DENB', 'denb'],
        'fegl': ['FEGL','Fe','FE','Fegl'],      
        'g1': ['G1','gg1','g1'],
        'flx_an': ['FLX_AN','Fluxo_Analitico','FLUXO_ANALITICO', 'fluxo_analitico'],
        'metodo': ['Metodo','METODO'],
        'tp':['TP','tp']    
    }

dataset = []

dataset.append(den_conv)
dataset.append(den_ggr)
dataset.append(den_gama)

for i in range(len(dataset)):
    dataset[i].columns = dataset[i].columns.str.lower()
    
# Correção do banco de dados
for target_column, possible_names in column_name_mapping.items():
    for possible_name in possible_names:
        for df_name in dataset:
            df = df_name
            if possible_name in df.columns:
                df.rename(columns={possible_name: target_column}, inplace=True)

for i in range(len(dataset)):
    print(list(dataset[i].columns))
                 
# Junção datasets
den_conv_c = list(den_conv.columns[den_conv.columns.isin(list(column_name_mapping.keys()))].unique())
den_ggr_c = list(den_ggr.columns[den_ggr.columns.isin(list(column_name_mapping.keys()))].unique())
den_gama_c = list(den_gama.columns[den_gama.columns.isin(list(column_name_mapping.keys()))].unique())

# Identify missing 
mis_gama_ggr = [item for item in den_gama_c if item not in den_ggr_c]
mis_gama_conv = [item for item in den_gama_c if item not in den_conv_c]
mis_conv_gama = [item for item in den_conv_c if item not in den_gama_c]


for i in mis_conv_gama:
  den_gama[i] = np.nan
  den_ggr[i] = np.nan
  den_ggr_c.append(i)
  den_gama_c.append(i)

for i in mis_gama_ggr:
  den_gama[i] = np.nan
  den_ggr[i] = np.nan
  den_ggr_c.append(i)
  den_gama_c.append(i)

for j in mis_gama_conv:
  den_gama[j] = np.nan
  den_conv[j] = np.nan
  den_conv_c.append(j)
  den_gama_c.append(j)

den_conv_c = list(set(den_conv_c))
den_ggr_c = list(set(den_ggr_c))
den_gama_c = list(set(den_gama_c))

den_gama = den_gama.loc[:, ~den_gama.columns.duplicated()].copy()
den_ggr = den_ggr.loc[:, ~den_ggr.columns.duplicated()].copy()
den_conv = den_conv.loc[:, ~den_conv.columns.duplicated()].copy()

den1 =  pd.concat([den_gama[den_ggr_c].reset_index(drop=True),den_ggr[den_ggr_c].reset_index(drop=True)])

den =   pd.concat([den1[den_conv_c].reset_index(drop=True),  den_conv[den_conv_c].reset_index(drop=True)])

#msk1 = (den['flx_an'].isna())
#den.loc[msk1,'flx_an'] = 'NULL'

den.columns = den.columns.str.upper()

den.to_csv(public_path /r'01_Dataset/04_Den/$(info[info.Parameters=='ddb_den'].Variables.iloc[0]).csv')




]]></python>
