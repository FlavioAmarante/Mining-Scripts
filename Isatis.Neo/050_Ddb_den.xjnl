c = app['project_path'] + "/public/06_Scripts/"
if c not in sys.path: sys.path.append(c)

import calc
import vale_gst_v25_1 as gst
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd]]></param>
        <param key="SCRIPT"><![CDATA[df = calc.as_df()

# Seleciona tipos de segmentos a serem removidos
remove = [200,300,400,500,600,650,700]


df['las_val']=0
msk = (df['COD'].isin(remove))
df.loc[msk,'las_val']=1


try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
