        <param key="SCRIPT"><![CDATA[df = calc.as_df()

varor = ['FE', 'AL', 'SI','MN', 'PF', 'P', 'MG', 'CA', 'TI'] 

var_fq = '2'

for i in varor:
  msk = ((df[f'FQ{var_fq}']>104) | (df[f'FQ{var_fq}']<95))
  df.loc[msk,f'{i}{var_fq}']=df.loc[msk,f'{i}GL']

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
