df.loc[m1,'$(varor[i])1'] = df.loc[m1,'A$(varor[i])1']/df.loc[m1,'G1']

m2 = (df['G2']>0)
df.loc[m2,'$(varor[i])2'] = df.loc[m2,'A$(varor[i])2']/df.loc[m2,'G2']

m3 = (df['G3']>0)
df.loc[m3,'$(varor[i])3'] = df.loc[m3,'A$(varor[i])3']/df.loc[m3,'G3']

m4 = (df['G4']>0)
df.loc[m4,'$(varor[i])4'] = df.loc[m4,'A$(varor[i])4']/df.loc[m4,'G4']


mg1 = (df['G1'].notna())

df.loc[mg1,'$(varor[i])GL_C'] = ((df.loc[mg1,'$(varor[i])1'] * df.loc[mg1,'G1'])
 + (df.loc[mg1,'$(varor[i])2'] * df.loc[mg1,'G2'])
 + (df.loc[mg1,'$(varor[i])3'] * df.loc[mg1,'G3'])
 + (df.loc[mg1,'$(varor[i])4'] * df.loc[mg1,'G4'])) / (df.loc[mg1,'G1'] + df.loc[mg1,'G2'] + df.loc[mg1,'G3'] + df.loc[mg1,'G4'])

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
            <param key="SCRIPT_END"/>
            <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
        </task>
