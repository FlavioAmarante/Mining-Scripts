        <param key="SCRIPT_START"><![CDATA[b = app['project_path'] + "/public/06_Scripts/py"
if b not in sys.path: sys.path.append(b)

c = app['project_path'] + "/public/06_Scripts/"
if c not in sys.path: sys.path.append(c)

import calc
import vale_gst_v25_1 as gst
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd]]></param>
        <param key="SCRIPT"><![CDATA[
df = calc.as_df()

lst_fec = ['FQ1','FQ2','FQ3','FQ4','FQGL','FQGL_C']

for i in lst_fec:
    print(f'{i} fora do range 95% - 104% :',df[(df[i]<95.000) | (df[i]>104.000)][i].count() )

df['aux_fq'] = np.nan
### MARCA BLOCOS COM FECHAMENTO QUÍMICO FORA DO RANGE 95%-104% 
for i in lst_fec:
	msk = (df[i] >104)|(df[i]<95)
	df.loc[msk,'aux_fq'] = 1

### MARCA FE > 70%
lst_fes = ['FEGL','FE1','FE2','FE3','FE4']
for i in lst_fes:
	msk = (df[i] >70)
	df.loc[msk,'aux_fq'] = 1 

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
