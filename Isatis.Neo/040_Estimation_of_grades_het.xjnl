            <param key="SCRIPT"><![CDATA[
df = calc.as_df()

var_f = '$(varn[i])'

ms1 = (df[f'G{var_f}'] <= 0)
df.loc[ms1,f'G{var_f}'] = 0
df.loc[ms1,f'AFE{var_f}'] = 0
df.loc[ms1,f'ASI{var_f}'] = 0
df.loc[ms1,f'AP{var_f}'] = 0
df.loc[ms1,f'AAL{var_f}'] = 0
df.loc[ms1,f'AMN{var_f}'] = 0
df.loc[ms1,f'APF{var_f}'] = 0
df.loc[ms1,f'ATI{var_f}'] = 0
df.loc[ms1,f'AMG{var_f}'] = 0
df.loc[ms1,f'ACA{var_f}'] = 0


m1 = (df[f'AFE{var_f}']<0)
df.loc[m1,f'AFE{var_f}'] = df[f'G{var_f}']*0.1
df.loc[m1,'aux_neg'] = 1

m2 = (df[f'ASI{var_f}']<0)
df.loc[m2,f'ASI{var_f}'] = df[f'G{var_f}']*0.1
df.loc[m2,'aux_neg'] = 1

m3 = (df[f'AP{var_f}']<0)
df.loc[m3,f'AP{var_f}'] = df[f'G{var_f}']*0.01
df.loc[m3,'aux_neg'] = 1

m4 = (df[f'AAL{var_f}']<0)
df.loc[m4,f'AAL{var_f}'] = df[f'G{var_f}']*0.1
df.loc[m4,'aux_neg'] = 1

m5 = (df[f'AMN{var_f}']<0)
df.loc[m5,f'AMN{var_f}'] = df[f'G{var_f}']*0.01
df.loc[m5,'aux_neg'] = 1

m6 = (df[f'APF{var_f}']<0)
df.loc[m6,f'APF{var_f}'] = df[f'G{var_f}']*0.1
df.loc[m6,'aux_neg'] = 1

m7 = (df[f'ATI{var_f}']<0)
df.loc[m7,f'ATI{var_f}'] = df[f'G{var_f}']*0.01
df.loc[m7,'aux_neg'] = 1

m8 = (df[f'AMG{var_f}']<0)
df.loc[m8,f'AMG{var_f}'] = df[f'G{var_f}']*0.01
df.loc[m8,'aux_neg'] = 1

m9 = (df[f'ACA{var_f}']<0)
df.loc[m9,f'ACA{var_f}'] = df[f'G{var_f}']*0.01
df.loc[m9,'aux_neg'] = 1

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
