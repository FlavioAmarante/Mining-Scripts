        <param key="SCRIPT"><![CDATA[df = calc.as_df()

lst_vars = ['FE','SI','AL','P','PF','MN','MG','CA','TI','G']


public_path = Path(app['project_public_path'])

par_est = pd.read_excel(
    public_path / "par.xlsx", sheet_name = 'estereis')

for a in $(est_dom):
  for b in lst_vars:
    msk = (df['lito']==a) & (df['buffer']>0) & (df[f'{b}1'].isna())
    df.loc[msk,f'{b}1'] =  par_est[(par_est.domain==a)][f'{b}1'].iloc[0]

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
