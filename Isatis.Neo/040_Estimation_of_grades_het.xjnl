            <param key="SCRIPT"><![CDATA[df = calc.as_df()


mak = (df['A$(varor[i])1'] >=0) & (df['A$(varor[i])2'] >=0) & (df['A$(varor[i])3'] >=0) & (df['A$(varor[i])4'] >=0)

df.loc[mak,'A$(varor[i])1'] = (100*df.loc[mak,'A$(varor[i])1']*df['$(varor[i])GL'])/(df.loc[mak,'A$(varor[i])1']+df.loc[mak,'A$(varor[i])2']+df.loc[mak,'A$(varor[i])3']+df.loc[mak,'A$(varor[i])4'])
df.loc[mak,'A$(varor[i])2'] = (100*df.loc[mak,'A$(varor[i])2']*df['$(varor[i])GL'])/(df.loc[mak,'A$(varor[i])1']+df.loc[mak,'A$(varor[i])2']+df.loc[mak,'A$(varor[i])3']+df.loc[mak,'A$(varor[i])4'])
df.loc[mak,'A$(varor[i])3'] = (100*df.loc[mak,'A$(varor[i])3']*df['$(varor[i])GL'])/(df.loc[mak,'A$(varor[i])1']+df.loc[mak,'A$(varor[i])2']+df.loc[mak,'A$(varor[i])3']+df.loc[mak,'A$(varor[i])4'])
df.loc[mak,'A$(varor[i])4'] = (100*df.loc[mak,'A$(varor[i])4']*df['$(varor[i])GL'])/(df.loc[mak,'A$(varor[i])1']+df.loc[mak,'A$(varor[i])2']+df.loc[mak,'A$(varor[i])3']+df.loc[mak,'A$(varor[i])4'])


try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
            <param key="SCRIPT_END"/>
            <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
        </task>
