            <param key="SCRIPT"><![CDATA[df = calc.as_df()

# Substitui nulos dos analitos por teores globais.
tipos = ['$(varor[i])']
num_t = ['1','2','3','4']

for i in tipos:
    for j in num_t:
        mask = (df[i+'GL']>0) & (df[i+j].isna()) & (df['aux_nan']>0)
        df.loc[mask, i+j] = df.loc[mask, i+'GL']

            


try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])
]]></param>
