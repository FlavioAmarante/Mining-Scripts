df = calc.as_df()

aux = -99

msk = (df['FE1']>69.9)
df.loc[msk,'FE1'] = 69.9
df.loc[msk,'AFE1'] = df.loc[msk,'FE1']*df.loc[msk,'G1']

msk = (df['FE2']>69.9)
df.loc[msk,'FE2'] = 69.9
df.loc[msk,'AFE2'] = df.loc[msk,'FE2']*df.loc[msk,'G2']

msk = (df['FE3']>69.9)
df.loc[msk,'FE3'] = 69.9
df.loc[msk,'AFE3'] = df.loc[msk,'FE3']*df.loc[msk,'G3']

msk = (df['FE4']>69.9)
df.loc[msk,'FE4'] = 69.9
df.loc[msk,'AFE4'] = df.loc[msk,'FE4']*df.loc[msk,'G4']


try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
