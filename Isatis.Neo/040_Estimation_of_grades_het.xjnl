            <param key="ITEM_7">COORD_METER</param>
            <param key="ITEM_8">ELEVATION_METER</param>
            <param key="ITEM_9">LENGTH_METER</param>
            <param key="ITEM_10">LENGTH_METER</param>
            <param key="ITEM_11">LENGTH_METER</param>
        </param>
        <param key="SYNTAX_MODE">PER_FILE</param>
