            <task id="data-delete">
                <param key="LIST">
                    <param key="ITEM_1">
                        <path>$(pasta_gra_ddb)</path>
                        <file>$(info[info.Parameters=='ddb_cac'].Variables.iloc[0])</file>
                        <table>Entry</table>
                        <macroVar>OUT_ALL_$(dom_sect[j])_$(sectors[k])</macroVar>
                    </param>
                </param>
            </task>
            <task id="data-delete">
                <param key="LIST">
                    <param key="ITEM_1">
                        <path>$(pasta_mb)</path>
                        <file>$(info[info.Parameters=='blockmodel'].Variables.iloc[0])</file>
                        <macroVar>OUT_BM_ALL_$(dom_sect[j])_$(sectors[k])_fx</macroVar>
                    </param>
                </param>
            </task>
        </for>
        <task id="create-macro_selection-from-rules" version="2">
            <param key="DATASET">
                <param key="ROOT">
                    <path>$(pasta_mb)</path>
                    <file>$(info[info.Parameters=='blockmodel'].Variables.iloc[0])</file>
                </param>
                <param key="OUT_CATEGORICAL">
                    <macroVar>fx_pass</macroVar>
                </param>
                <param key="RULES">
                    <param key="VARIABLES">
                        <param key="ITEM_1">
                            <variable>lito</variable>
                        </param>
                        <param key="ITEM_2">
                            <variable>setor</variable>
                        </param>
                        <param key="ITEM_3">
                            <variable>AFE1</variable>
                        </param>
                        <param key="ITEM_4"/>
                    </param>
                    <param key="RULES">
                        <param key="ITEM_4">
                            <param key="NAME">1</param>
                            <param key="COND">v2 == '$(sectors[k])' and v3 >0</param>
                        </param>
                    </param>
                </param>
            </param>
            <param key="DISPLAY_OUTPUT">
                <param key="SCENE"/>
            </param>
            <param key="MACRO_MODE">Append to Existing Macro</param>
        </task>
    </for>
    <comment>--- Estima Sem Outliers Faixas ---</comment>
    <for end="len(sectors)-1" start="0" index="k">
        <python><![CDATA[print('Setores:',sectors)
print('N:',len(sectors))
dom_sect = par_estima[par_estima.setor==sectors[k]].domain.unique()
print('Dominios:',dom_sect)
print('N Dom:',len(dom_sect))
groups_sect = list(par_estima[par_estima.setor==sectors[k]].grupo)
print('Grupo:',groups_sect)
print('N Grupo:',len(groups_sect))]]></python>
        <for end="len(dom_sect)-1" start="0" index="j">
            <task id="create-macro_selection-from-rules" version="2">
                <param key="DATASET">
                    <param key="ROOT">
                        <path>$(pasta_gra_ddb)</path>
