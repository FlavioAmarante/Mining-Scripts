                    <task id="neigh-set-create" version="2">
                        <param key="TASK_MODE">yes</param>
                        <param key="NEIGH_GROUP">
                            <param key="INPUT_DATASET">
                                <param key="ROOT">
                                    <path>$(pasta_gra_ddb)</path>
                                    <file>$(info[info.Parameters=='ddb_cac'].Variables.iloc[0])</file>
                                </param>
                            </param>
                            <param key="INPUT_GEOSET"/>
                            <param key="NEIGHBORHOOD_PARAM">
                                <param key="NEIGH_TYPE">NEW_MOVING</param>
                                <param key="EXISTING"/>
                                <param version="3" key="MOVING_DEF">
                                    <param key="MOVING_MODE">FROM_ELLIPSOID</param>
                                    <param key="SEARCH_ELLIPSOID">
                                        <param automatic="no" key="ROTATION">
                                            <dip>$(vario_teor[(vario_teor.grupo==groups_sect[j])&amp;(vario_teor.setor==sectors[k])].dip.iloc[0])</dip>
                                            <dipAzimuth>$(vario_teor[(vario_teor.grupo==groups_sect[j])&amp;(vario_teor.setor==sectors[k])].dipaz.iloc[0])</dipAzimuth>
                                            <pitch>$(vario_teor[(vario_teor.grupo==groups_sect[j])&amp;(vario_teor.setor==sectors[k])].pitch.iloc[0])</pitch>
                                        </param>
                                        <param automatic="no" key="SEARCH_ELLIPSOID">
                                            <v1>$(par_estima[(par_estima.domain==dom_sect[j])&amp;(par_estima.setor==sectors[k])].U.iloc[0])</v1>
                                            <v2>$(par_estima[(par_estima.domain==dom_sect[j])&amp;(par_estima.setor==sectors[k])].V.iloc[0])</v2>
                                            <v3>$(par_estima[(par_estima.domain==dom_sect[j])&amp;(par_estima.setor==sectors[k])].W.iloc[0])</v3>
                                        </param>
                                        <param key="PREVIEW_NEIGHBORHOOD_SCENE">
                                            <param key="SCENE"/>
                                        </param>
                                        <param key="USE_ANISOTROPIC_DISTANCE">yes</param>
                                    </param>
                                    <param key="SECTORS">
                                        <param key="ANGULAR_SECTOR">$(par_estima[(par_estima.domain==dom_sect[j])&amp;(par_estima.setor==sectors[k])].n_sectors.iloc[0])</param>
                                        <param key="MAX_PER_SECTOR">$(par_estima[(par_estima.domain==dom_sect[j])&amp;(par_estima.setor==sectors[k])].max_sector.iloc[0])</param>
                                        <param key="SPLIT_SECTORS">no</param>
                                    </param>
                                    <param key="ADVANCED">
                                        <param key="APPLY_HETEROTOPIC_SEARCH">no</param>
                                        <param key="SELECT_ALL_SAMPLES_IN_TARGET">no</param>
                                        <param key="MINIMUM_DISTANCE_BETWEEN_TWO_SELECTED_SAMPLES">no</param>
                                        <param key="MINIMUM_DISTANCE_BETWEEN_TWO_SELECTED_SAMPLES_VALUE">0</param>
                                        <param key="USE_MAXIMUM_SAMPLES">yes</param>
                                        <param key="MAXIMUM_SAMPLES">$(par_estima[(par_estima.domain==dom_sect[j])&amp;(par_estima.setor==sectors[k])].max_samples.iloc[0])</param>
                                    </param>
                                    <param key="DIVIDE_CODE">
                                        <param key="OPTIMUM_NUMBER_OF_SAMPLES_PER_CODE">no</param>
                                        <param key="OPTIMUM_NUMBER_OF_SAMPLES_PER_CODE_VALUE">1</param>
                                        <param key="MAXIMUM_NUMBER_OF_SAMPLES_PER_CODE">no</param>
                                        <param key="MAXIMUM_NUMBER_OF_SAMPLES_PER_CODE_VALUE">1</param>
                                        <param key="USE_MINIMUM_NUMBER_OF_CODES">no</param>
                                        <param key="MINIMUM_NUMBER_OF_CODES">1</param>
                                        <param key="USE_MAXIMUM_NUMBER_OF_CODES">no</param>
                                        <param key="MAXIMUM_NUMBER_OF_CODES">1</param>
                                        <param key="CODE_VARIABLE"/>
                                    </param>
                                    <param key="SHORTCUTS">
                                        <param key="MINIMUM_SAMPLES_ACTIVATED">yes</param>
                                        <param key="MINIMUM_SAMPLES">$(par_estima[(par_estima.domain==dom_sect[j])&amp;(par_estima.setor==sectors[k])].min_samples.iloc[0])</param>
                                        <param key="MAXIMUM_DISTANCE_WITHOUT_ANY_SAMPLE">no</param>
                                        <param key="MAXIMUM_DISTANCE_WITHOUT_ANY_SAMPLE_VALUE">0</param>
                                        <param key="MAXIMUM_NUMBER_OF_CONSECUTIVE_EMPTY_SECTOR">no</param>
                                        <param key="MAXIMUM_EMPTY_SECTOR_IS_CONSECUTIVE">yes</param>
                                        <param key="MAXIMUM_NUMBER_OF_CONSECUTIVE_EMPTY_SECTOR_VALUE">1</param>
                                        <param key="MAXIMUM_NUMBER_OF_SAMPLES_PER_BLOCK">no</param>
                                        <param key="MAXIMUM_NUMBER_OF_SAMPLES_PER_BLOCK_VALUE">1</param>
                                        <param key="PROXIMITY_RECTANGLE_ACTIVATED">no</param>
                                        <param key="PROXIMITY_RECTANGLE">
                                            <v1>0</v1>
                                            <v2>0</v2>
                                            <v3>0</v3>
                                        </param>
                                    </param>
                                    <param key="CAPPING">
                                        <param key="LARGE_CUTOFF">
                                            <param key="LARGE_CUTOFF_USED">no</param>
                                            <param key="LARGE_CUTOFF_VARIABLE"/>
                                            <param key="LARGE_CUTOFF_MODE">CUTOFF_REPLACE</param>
                                            <param key="LARGE_CUTOFF_THRESHOLD">0</param>
                                            <param automatic="yes" key="LARGE_CUTOFF_DISTANCE">
                                                <v1>63.75</v1>
                                                <v2>63.75</v2>
                                                <v3>63.75</v3>
                                            </param>
                                        </param>
                                        <param key="SMALL_CUTOFF">
                                            <param key="SMALL_CUTOFF_USED">no</param>
                                            <param key="SMALL_CUTOFF_VARIABLE"/>
                                            <param key="SMALL_CUTOFF_MODE">CUTOFF_REPLACE</param>
                                            <param key="SMALL_CUTOFF_THRESHOLD">0</param>
                                            <param automatic="yes" key="SMALL_CUTOFF_DISTANCE">
                                                <v1>63.75</v1>
                                                <v2>63.75</v2>
                                                <v3>63.75</v3>
                                            </param>
                                        </param>
                                    </param>
