        <param key="SCRIPT"><![CDATA[
df = calc.as_df()


# Fechamento Químico
def feq_mb(df1,var_fq):
  df1[f'FQ{var_fq}'] = np.nan
  
  m1 = (df1[f'MN{var_fq}'] <= 2.5)
  df1.loc[m1,f'FQ{var_fq}'] = round((df1.loc[m1,f'FE{var_fq}']  * 1.4297) + df1.loc[m1,f'SI{var_fq}'] + (df1.loc[m1,f'P{var_fq}'] * 2.2913) + df1.loc[m1,f'AL{var_fq}'] + (df1.loc[m1,f'MN{var_fq}'] * 1.2912) + df1.loc[m1,f'PF{var_fq}'] + df1.loc[m1,f'CA{var_fq}'] + df1.loc[m1,f'MG{var_fq}'] + df1.loc[m1,f'TI{var_fq}'],3)
  
  m2 = (df1[f'MN{var_fq}'] > 2.5)
  df1.loc[m2,f'FQ{var_fq}'] = round((df1.loc[m2,f'FE{var_fq}']  * 1.4297) + df1.loc[m2,f'SI{var_fq}'] + (df1.loc[m2,f'P{var_fq}'] * 2.2913) + df1.loc[m2,f'AL{var_fq}'] + (df1.loc[m2,f'MN{var_fq}'] * 1.4369) + df1.loc[m2,f'PF{var_fq}'] + df1.loc[m2,f'CA{var_fq}'] + df1.loc[m2,f'MG{var_fq}'] + df1.loc[m2,f'TI{var_fq}'],3)
  	
  return df1

df = feq_mb(df,'GL_NN')

msk = (df['FEGL'].isna()) | (df['FEGL']<0)
df.loc[msk,'FQGL_NN'] = np.nan

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
    </task>
