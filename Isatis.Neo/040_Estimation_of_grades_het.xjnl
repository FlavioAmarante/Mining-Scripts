                    <param key="NAME">vmod_$(dom_sect[j])_$(sectors[k])_FX</param>
                </task>
                <task id="neigh-set-create" version="2">
                    <param key="TASK_MODE">yes</param>
                    <param key="NEIGH_GROUP">
                        <param key="INPUT_DATASET">
                            <param key="ROOT">
                                <path>$(pasta_gra_ddb)</path>
                                <file>$(info[info.Parameters=='ddb_cac'].Variables.iloc[0])</file>
                            </param>
                        </param>
                        <param key="INPUT_GEOSET"/>
                        <param key="NEIGHBORHOOD_PARAM">
                            <param key="NEIGH_TYPE">NEW_MOVING</param>
                            <param key="EXISTING"/>
                            <param version="3" key="MOVING_DEF">
                                <param key="MOVING_MODE">FROM_ELLIPSOID</param>
                                <param key="SEARCH_ELLIPSOID">
                                    <param automatic="no" key="ROTATION">
                                        <dip>$(vario_teor[(vario_teor.grupo==groups_sect[j])&amp;(vario_teor.setor==sectors[k])].dip.iloc[0])</dip>
                                        <dipAzimuth>$(vario_teor[(vario_teor.grupo==groups_sect[j])&amp;(vario_teor.setor==sectors[k])].dipaz.iloc[0])</dipAzimuth>
                                        <pitch>$(vario_teor[(vario_teor.grupo==groups_sect[j])&amp;(vario_teor.setor==sectors[k])].pitch.iloc[0])</pitch>
                                    </param>
                                    <param automatic="no" key="SEARCH_ELLIPSOID">
                                        <v1>$(par_estima[(par_estima.domain==dom_sect[j])&amp;(par_estima.setor==sectors[k])].U.iloc[0])</v1>
                                        <v2>$(par_estima[(par_estima.domain==dom_sect[j])&amp;(par_estima.setor==sectors[k])].V.iloc[0])</v2>
                                        <v3>$(par_estima[(par_estima.domain==dom_sect[j])&amp;(par_estima.setor==sectors[k])].W.iloc[0])</v3>
                                    </param>
                                    <param key="PREVIEW_NEIGHBORHOOD_SCENE">
                                        <param key="SCENE"/>
                                    </param>
                                    <param key="USE_ANISOTROPIC_DISTANCE">yes</param>
                                </param>
                                <param key="SECTORS">
                                    <param key="ANGULAR_SECTOR">$(par_estima[(par_estima.domain==dom_sect[j])&amp;(par_estima.setor==sectors[k])].n_sectors.iloc[0])</param>
                                    <param key="MAX_PER_SECTOR">$(par_estima[(par_estima.domain==dom_sect[j])&amp;(par_estima.setor==sectors[k])].max_sector.iloc[0])</param>
                                    <param key="SPLIT_SECTORS">no</param>
                                </param>
                                <param key="ADVANCED">
                                    <param key="APPLY_HETEROTOPIC_SEARCH">no</param>
