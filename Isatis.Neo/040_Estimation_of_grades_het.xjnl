        <param key="SCRIPT"><![CDATA[folder = app['project_path'] + "/public/04_Estimation/01_Grade/"

df = calc.as_df()

cac = pd.read_csv('$(folder_cac)'+'/cac_assay.csv')

print(cac.head())

######################################################
lst_glb = ['FEGL', 'SIGL', 'PGL', 'ALGL', 'MNGL', 'PFGL', 'TIGL', 'MGGL', 'CAGL']

# Tipologia de minérios
lito_ore = ['CG','IGO', 'IFR', 'IF', 'IC', 'HGO', 'HF', 'HC','IAL','IMN','RO','IDO','FFGR', 'FFG']
lito_ore_upper = [element.upper() for element in lito_ore]
lito_ore_lower = [element.lower() for element in lito_ore]
lito_est = ['AT', 'IN', 'SR',  'FL', 'LT', 'QF', 'FD', 'DO', 'QT', 'FG','DT', 'CH']
lito_est_upper = [element.upper() for element in lito_ore]
lito_est_lower = [element.lower() for element in lito_ore]

######################################################

bmf_check = df

val_cac_mb = pd.DataFrame()
val_cac_mb['lito'] = bmf_check['lito'].unique()

for i in lito_ore:
    for j in lst_glb:
        mask1 = (val_cac_mb['lito']==i)
        val_cac_mb.loc[mask1, str(j)+'_MB_min'] = bmf_check[bmf_check['lito'] == i][j].min()
        val_cac_mb.loc[mask1, str(j)+'_MB_max'] = bmf_check[bmf_check['lito'] == i][j].max()
        val_cac_mb.loc[mask1, str(j)+'_CAC_min'] = cac[(cac['CLI'] == i)&(cac['Length']>4.5)][j].min()
        val_cac_mb.loc[mask1, str(j)+'_CAC_max'] = cac[(cac['CLI'] == i)&(cac['Length']>4.5)][j].max()
        val_cac_mb.loc[mask1, str(j)+'_dif_min'] = val_cac_mb.loc[mask1, str(j)+'_MB_min'] - val_cac_mb.loc[mask1, str(j)+'_CAC_min']
        val_cac_mb.loc[mask1, str(j)+'_dif_max'] = val_cac_mb.loc[mask1, str(j)+'_MB_max'] - val_cac_mb.loc[mask1, str(j)+'_CAC_max']
        
# Validação
for i in lito_ore:
    for j in lst_glb:
        mask1 = (val_cac_mb['lito'] == i)

        if (val_cac_mb.loc[mask1, str(j)+'_dif_min'] < -0.001).any():
            print('Lito', i, 'minimum', j, 'não positivo !')
        elif (val_cac_mb.loc[mask1, str(j)+'_dif_max'] > 0.001).any():
            print('Lito', i, 'maximum', j, 'não negativo !')
        else: 
            print('Lito',i,'var',j,'validado')       ]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
    </task>
