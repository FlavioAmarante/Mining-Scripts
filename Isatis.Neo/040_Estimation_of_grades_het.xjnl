        <param key="SCRIPT"><![CDATA[
df = calc.as_df()

var_fq = '1'

df.columns = df.columns.str.lower()

mask = (df[f'g{var_fq}'] > 0) 

df.loc[mask,f'afe{var_fq}'] = np.nan
df.loc[mask,f'asi{var_fq}'] = np.nan
df.loc[mask,f'ap{var_fq}'] = np.nan
df.loc[mask,f'aal{var_fq}'] = np.nan
df.loc[mask,f'amn{var_fq}'] = np.nan
df.loc[mask,f'apf{var_fq}'] = np.nan
df.loc[mask,f'ati{var_fq}'] = np.nan
df.loc[mask,f'amg{var_fq}'] = np.nan
df.loc[mask,f'aca{var_fq}'] = np.nan

# ACUMULACAO

df.loc[mask, f'afe{var_fq}'] = (np.nan_to_num(df.loc[mask, f'fe{var_fq}'] * df.loc[mask, f'g{var_fq}'])  )
df.loc[mask, f'asi{var_fq}'] = (np.nan_to_num(df.loc[mask, f'si{var_fq}'] * df.loc[mask, f'g{var_fq}'])  )
df.loc[mask, f'ap{var_fq}'] = (np.nan_to_num(df.loc[mask, f'p{var_fq}'] * df.loc[mask, f'g{var_fq}'])    )
df.loc[mask, f'aal{var_fq}'] = (np.nan_to_num(df.loc[mask, f'al{var_fq}'] * df.loc[mask, f'g{var_fq}'])  )
df.loc[mask, f'amn{var_fq}'] = (np.nan_to_num(df.loc[mask,f'mn{var_fq}'] * df.loc[mask, f'g{var_fq}'])  )
df.loc[mask, f'apf{var_fq}'] = (np.nan_to_num(df.loc[mask, f'pf{var_fq}'] * df.loc[mask, f'g{var_fq}'])  )
df.loc[mask, f'ati{var_fq}'] = (np.nan_to_num(df.loc[mask, f'ti{var_fq}'] * df.loc[mask, f'g{var_fq}'])  )
df.loc[mask, f'amg{var_fq}'] = (np.nan_to_num(df.loc[mask, f'mg{var_fq}'] * df.loc[mask, f'g{var_fq}'])  )
df.loc[mask, f'aca{var_fq}'] = (np.nan_to_num(df.loc[mask, f'ca{var_fq}'] * df.loc[mask, f'g{var_fq}'])  )

# Zera onde retido nas faixas = 0

mask = (df[f'g{var_fq}'] == 0) 

df.loc[mask, f'afe{var_fq}'] = 0
df.loc[mask, f'asi{var_fq}'] = 0
df.loc[mask, f'ap{var_fq}']  = 0
df.loc[mask, f'aal{var_fq}'] = 0
df.loc[mask, f'amn{var_fq}'] = 0
df.loc[mask, f'apf{var_fq}'] = 0
df.loc[mask, f'ati{var_fq}'] = 0
df.loc[mask, f'amg{var_fq}'] = 0
df.loc[mask, f'aca{var_fq}'] = 0

df.columns = df.columns.str.upper()

try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
