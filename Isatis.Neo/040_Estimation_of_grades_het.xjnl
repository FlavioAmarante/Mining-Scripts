        <param key="TRY_COMPILED">no</param>
        <param key="MACRO_MODE">LOOP_OVER_INDICES</param>
        <param key="SCRIPT_START"><![CDATA[b = app['project_path'] + "/public/06_Scripts/py"
if b not in sys.path: sys.path.append(b)

c = app['project_path'] + "/public/06_Scripts/"
if c not in sys.path: sys.path.append(c)

import calc
import vale_gst_v25_1 as gst
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd
from pathlib import Path]]></param>
        <param key="SCRIPT"><![CDATA[# Import Pastas
public_path = Path(app['project_public_path'])
folder_cac = app['project_path'] + "/public/01_Dataset/03_Cac"
df = calc.as_df()

from sklearn.ensemble import IsolationForest
model_IF = IsolationForest(contamination = 0.05, random_state = 42)

msk = (df['FEGL'].notna()) # drop nan
anomaly_vars = ['X', 'Y', 'Z','FEGL', 'SIGL', 'PGL', 'ALGL', 'MNGL', 'PFGL', 'TIGL', 'MGGL', 'CAGL']

model_IF.fit(df[msk][anomaly_vars])

msk = (df['FEGL'].notna()) & (df['CLI'].isin($(lito_ore)))
df['AN_SCORES'] = np.nan
df.loc[msk,'AN_SCORES'] = model_IF.decision_function(df[msk][anomaly_vars])
df['ANOMALY'] = np.nan
df.loc[msk,'ANOMALY'] = model_IF.predict(df[msk][anomaly_vars])

out_isolation = df.groupby(['CLI','ANOMALY'])['ANOMALY'].count()
out_isolation.to_csv(folder_cac+ '/outliers_iso_forest.csv')

outvar = pd.read_excel(public_path / "par.xlsx", sheet_name = 'outliers')

out_par = pd.read_excel(public_path / "par.xlsx", sheet_name = 'nn_outliers')
out_par = out_par[out_par['forest']=='Y']

# Initialize OUT column
df['OUT'] = 0

# Get unique values for variable and lito
unique_variables = list(outvar['variable'].unique())
unique_litos = list(outvar['lito'].unique())

nn_litos = list(out_par['domain'].unique())

# Loop through unique variables and litos
for k in unique_litos:
    for i in unique_variables:
      m1 = (outvar['lito'] == k) & (outvar['variable'] == i)
      if len(list(outvar[m1]['inf_limit']))> 0:
        msk = (df['CLI'] == k) & ((df[i] < float(outvar[m1]['inf_limit']))|(df[i] > float(outvar[m1]['sup_limit'])))
        df.loc[msk, 'OUT'] = 1   

# Aplica outliers IsolationForest
msk2 = (df['ANOMALY']==-1) & (df['CLI'].isin(nn_litos))
df.loc[msk2,'OUT'] = 1

# Retorno variáveis
try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
