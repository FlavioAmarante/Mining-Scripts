        <param key="SCRIPT"><![CDATA[df = calc.as_df()

#---- Normaliza ---

df['ax_g1'] = np.nan
df['ax_g2'] = np.nan
df['ax_g3'] = np.nan
df['ax_g4'] = np.nan

msk = (df['G1']>=0) & (df['G2']>=0) & (df['G3']>=0) & (df['G4']>=0) 

df.loc[msk,'FGRA'] = df.loc[msk,'G1']+df.loc[msk,'G2']+df.loc[msk,'G3']+df.loc[msk,'G4']

df.loc[msk,'ax_g1'] = 100*(df.loc[msk,'G1']/df.loc[msk,'FGRA'])
df.loc[msk,'ax_g2'] = 100*(df.loc[msk,'G2']/df.loc[msk,'FGRA'])
df.loc[msk,'ax_g3'] = 100*(df.loc[msk,'G3']/df.loc[msk,'FGRA'])
df.loc[msk,'ax_g4'] = 100*(df.loc[msk,'G4']/df.loc[msk,'FGRA'])


msk2 = (df['ax_g1']>=0) & (df['ax_g2']>=0) & (df['ax_g3']>=0) & (df['ax_g4']>=0) 

df.loc[msk2,'G1'] = df.loc[msk2,'ax_g1'] 
df.loc[msk2,'G2'] = df.loc[msk2,'ax_g2'] 
df.loc[msk2,'G3'] = df.loc[msk2,'ax_g3'] 
df.loc[msk2,'G4'] = df.loc[msk2,'ax_g4'] 


try:
  for v, d in info["vars"].items():
    locals()[v][:] = df[d["name"]]
    print(v, d["name"])
except KeyError:
  print('ERROR:',v, d["name"])]]></param>
        <param key="SCRIPT_END"/>
        <param key="EXAMPLE">GRID_SAMPLING_MEANS</param>
    </task>
